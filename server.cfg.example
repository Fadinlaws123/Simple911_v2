# Simple911 v2
ensure Simple911_v2

# Give a group access to responder features.
add_ace group.admin simple911.responder allow

# Optional: give dedicated dispatchers the dispatcher role.
# When dispatcher-priority routing is enabled, new calls notify dispatchers first.
add_ace group.admin simple911.dispatcher allow

# Example: give one identifier responder access directly.
# add_ace identifier.license:YOUR_LICENSE_HERE simple911.responder allow

# Example: give one identifier dispatcher access directly.
# add_ace identifier.license:YOUR_LICENSE_HERE simple911.dispatcher allow
